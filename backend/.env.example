# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================
# Copiar este archivo a .env y ajustar los valores

# Database Configuration
# Formato: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://empanadas_user:empanadas_pass@localhost:5432/empanadas_db

# CORS Origins (separados por coma, sin espacios)
# Desarrollo: http://localhost:5173
# Producción: http://tu-dominio.com:9000
CORS_ORIGINS=http://localhost:5173,http://localhost:9000

# JWT Configuration
JWT_SECRET_KEY=cambiar-esta-clave-en-produccion-usar-algo-seguro
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Initial Admin User (solo para setup inicial)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@empanadas.com
FIRST_ADMIN_PASSWORD=admin123
